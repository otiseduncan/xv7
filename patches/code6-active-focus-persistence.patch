+    @staticmethod
+    def _truthy_env(name: str) -> bool:
+        return os.getenv(name, "").strip().lower() in {"1", "true", "yes", "on"}
+
+    @staticmethod
+    def _same_path(left: Path, right: Path) -> bool:
+        try:
+            return left.resolve(strict=False) == right.resolve(strict=False)
+        except (OSError, RuntimeError):
+            return left.absolute() == right.absolute()
+
+    def _guard_runtime_records_dir(self, runtime_dir: Path, *, source: str) -> Path:
+        if self._allow_seed_record_writes:
+            return runtime_dir
+        if source in {"env", "argument"} and self._same_path(runtime_dir, self.records_dir):
+            return Path(os.getenv("XV7_BRAIN_RUNTIME_FALLBACK_PATH", "data/brain/runtime_records"))
+        return runtime_dir
