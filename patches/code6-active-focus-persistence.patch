     def _runtime_record_path(self, record_id: str) -> Path:
         return self.runtime_records_dir / f"{record_id}.json"
+
+    def _assert_runtime_store_writable(self) -> None:
+        if (
+            not self._allow_seed_record_writes
+            and self._same_path(self.runtime_records_dir, self.records_dir)
+        ):
+            raise RuntimeError(
+                "Refusing to write runtime brain records into the seed record store. "
+                "Set XV7_BRAIN_RUNTIME_RECORDS_PATH to a writable runtime directory."
+            )
+
+        probe_path = self.runtime_records_dir / ".xv7-write-probe"
+        try:
+            self.runtime_records_dir.mkdir(parents=True, exist_ok=True)
+            probe_path.write_text("ok\n", encoding="utf-8")
+            if probe_path.read_text(encoding="utf-8") != "ok\n":
+                raise RuntimeError("runtime write probe mismatch")
+        except Exception as exc:
+            raise RuntimeError(
+                f"Brain runtime record store is not writable: {self.runtime_records_dir}."
+            ) from exc
+        finally:
+            try:
+                if probe_path.exists():
+                    probe_path.unlink()
+            except OSError:
+                pass
 
