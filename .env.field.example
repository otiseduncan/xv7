# =============================================================================
# XV7 / Xoduz — Field Laptop Environment
# =============================================================================
# Copy to .env on the field laptop:
#   cp .env.field.example .env
# =============================================================================

ENV=development

OLLAMA_PORT=11434
WEBUI_PORT=8080
CORE_PORT=8000

OLLAMA_VERSION=latest
OLLAMA_ORIGINS=*
OLLAMA_MODELS_PATH=ollama_data

# Field laptop rescue setting: tiny model first, stable communication first.
XV7_MODEL_PROFILE=low_resource
DEFAULT_MODELS=qwen3:0.6b

WEBUI_SECRET_KEY=CHANGE_ME_generate_a_strong_secret_key_here
WEBUI_AUTH=true

ENABLE_RAG_WEB_SEARCH=false
RAG_WEB_SEARCH_ENGINE=

CORE_API_KEY=CHANGE_ME_generate_a_strong_api_key_here
LOG_LEVEL=INFO

DB_PATH=/app/data/xv7.db
VECTOR_DB_PATH=/app/data/vectors
MEMORY_DB_PATH=/app/data/memory
ASSETS_PATH=/app/shared/assets
XV7_HOST_SANDBOX=./generated-sites

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
