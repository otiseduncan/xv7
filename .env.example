# =============================================================================
# xv7 — Environment Variables Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked CHANGE_ME before running docker compose up.
# 3. NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Runtime Environment
# ---------------------------------------------------------------------------
ENV=development                         # development | staging | production

# ---------------------------------------------------------------------------
# Service Ports  (host-side bindings — change if a port is already in use)
# ---------------------------------------------------------------------------
OLLAMA_PORT=11434                       # Ollama inference REST API
WEBUI_PORT=8080                         # Open WebUI browser interface
CORE_PORT=8000                          # xv7 Core orchestration API

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------
OLLAMA_VERSION=latest                   # Pin to a tag when needed
OLLAMA_ORIGINS=*                        # CORS origins allowed by Ollama

# Optional host model path.
# Leave blank/default to use Docker named volume ollama_data.
# Linux example:  OLLAMA_MODELS_PATH=/home/naomi/.ollama
# Windows example: OLLAMA_MODELS_PATH=C:/Users/otisd/.ollama
OLLAMA_MODELS_PATH=ollama_data

# ---------------------------------------------------------------------------
# Model Profile Selection
# Runtime role tags are centralized in config/models.yml.
# Rescue default is low_resource so the CPU laptop can boot and talk first.
# Use balanced/local_test/large_code only after those models are actually pulled.
# ---------------------------------------------------------------------------
XV7_MODEL_PROFILE=low_resource          # low_resource | balanced | local_test | large_code

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEBUI_SECRET_KEY=CHANGE_ME_generate_a_strong_secret_key_here
WEBUI_AUTH=true                         # true = login required

# RAG / web-search integration (optional)
ENABLE_RAG_WEB_SEARCH=false
RAG_WEB_SEARCH_ENGINE=                  # searxng | brave | serpapi

# ---------------------------------------------------------------------------
# xv7 Core Service
# ---------------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CORE_API_KEY=CHANGE_ME_generate_a_strong_api_key_here
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# System Paths  (inside containers — adjust if you mount custom host paths)
# ---------------------------------------------------------------------------

# Structured / relational storage
DB_PATH=/app/data/xv7.db               # SQLite database used by Core

# Vector / semantic memory store (ChromaDB or FAISS)
VECTOR_DB_PATH=/app/data/vectors        # Persisted embedding collections

# Long-term agent memory journals (JSON / JSONL)
MEMORY_DB_PATH=/app/data/memory         # Episodic & semantic memory logs

# 3D avatar and static UI assets shared between Core and Open WebUI
ASSETS_PATH=/app/shared/assets          # Mounted as xv7_shared volume

# Optional: host-visible sandbox export root for /app/generated-sites.
# Default keeps exports under ./generated-sites in the repo directory.
# For Windows host-visible exports, set: XV7_HOST_SANDBOX=X:/xoduz-sandbox
XV7_HOST_SANDBOX=./generated-sites

# ---------------------------------------------------------------------------
# External API Keys  (all optional — used only for hybrid / fallback modes)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
